<routes>
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" maxSpeed="13.9"/>

    <!-- ===== ROTTE CHE ATTRAVERSANO SOLO L'INCROCIO 1 ===== -->
    <route id="N1_W1"   edges="n1_c1 c1_w1"/>
    <route id="W1_N1"   edges="w1_c1 c1_n1"/>
    <route id="W1_S1"   edges="w1_c1 c1_s1"/>
    <route id="S1_W1"   edges="s1_c1 c1_w1"/>

    <!-- ===== ROTTE CHE ATTRAVERSANO SOLO L'INCROCIO 2 ===== -->
    <route id="N2_E2"   edges="n2_c2 c2_e2"/>
    <route id="E2_N2"   edges="e2_c2 c2_n2"/>
    <route id="E2_S2"   edges="e2_c2 c2_s2"/>
    <route id="S2_E2"   edges="s2_c2 c2_e2"/>

    <!-- ===== ROTTE CHE ATTRAVERSANO ENTRAMBI GLI INCROCI ===== -->
    <!-- Da ovest a est (W1 → C1 → C2 → E2) -->
    <route id="W1_E2"   edges="w1_c1 c1_c2 c2_e2"/>
    <!-- Da est a ovest (E2 → C2 → C1 → W1) -->
    <route id="E2_W1"   edges="e2_c2 c2_c1 c1_w1"/>

    <!-- Nord1 → Est2 -->
    <route id="N1_E2"   edges="n1_c1 c1_c2 c2_e2"/>
    <!-- Nord1 → Nord2 -->
    <route id="N1_N2"   edges="n1_c1 c1_c2 c2_n2"/>
    <!-- Nord1 → Sud2 -->
    <route id="N1_S2"   edges="n1_c1 c1_c2 c2_s2"/>

    <!-- Sud1 → Est2 -->
    <route id="S1_E2"   edges="s1_c1 c1_c2 c2_e2"/>
    <!-- Sud1 → Nord2 -->
    <route id="S1_N2"   edges="s1_c1 c1_c2 c2_n2"/>
    <!-- Sud1 → Sud2 -->
    <route id="S1_S2"   edges="s1_c1 c1_c2 c2_s2"/>

    <!-- Est2 → Nord1 -->
    <route id="E2_N1"   edges="e2_c2 c2_c1 c1_n1"/>
    <!-- Est2 → Sud1 -->
    <route id="E2_S1"   edges="e2_c2 c2_c1 c1_s1"/>

    <!-- Nord2 → Ovest1 -->
    <route id="N2_W1"   edges="n2_c2 c2_c1 c1_w1"/>
    <!-- Sud2 → Ovest1 -->
    <route id="S2_W1"   edges="s2_c2 c2_c1 c1_w1"/>

    <!-- ===== FLUSSI DI TRAFFICO ===== -->

    <!-- Traffico asse principale est-ovest -->
    <flow id="f_W1_E2"  type="car" route="W1_E2"  begin="0" end="3600" vehsPerHour="300"/>
    <flow id="f_E2_W1"  type="car" route="E2_W1"  begin="0" end="3600" vehsPerHour="300"/>

    <!-- Traffico locale incrocio 1 -->
    <flow id="f_N1_W1"  type="car" route="N1_W1"  begin="0" end="3600" vehsPerHour="120"/>
    <flow id="f_W1_N1"  type="car" route="W1_N1"  begin="0" end="3600" vehsPerHour="120"/>
    <flow id="f_W1_S1"  type="car" route="W1_S1"  begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_S1_W1"  type="car" route="S1_W1"  begin="0" end="3600" vehsPerHour="100"/>

    <!-- Traffico locale incrocio 2 -->
    <flow id="f_N2_E2"  type="car" route="N2_E2"  begin="0" end="3600" vehsPerHour="120"/>
    <flow id="f_E2_N2"  type="car" route="E2_N2"  begin="0" end="3600" vehsPerHour="120"/>
    <flow id="f_E2_S2"  type="car" route="E2_S2"  begin="0" end="3600" vehsPerHour="100"/>
    <flow id="f_S2_E2"  type="car" route="S2_E2"  begin="0" end="3600" vehsPerHour="100"/>

    <!-- Traffico Nord/Sud attraverso entrambi gli incroci -->
    <flow id="f_N1_E2"  type="car" route="N1_E2"  begin="0" end="3600" vehsPerHour="80"/>
    <flow id="f_N1_N2"  type="car" route="N1_N2"  begin="0" end="3600" vehsPerHour="60"/>
    <flow id="f_N1_S2"  type="car" route="N1_S2"  begin="0" end="3600" vehsPerHour="60"/>
    <flow id="f_S1_E2"  type="car" route="S1_E2"  begin="0" end="3600" vehsPerHour="80"/>
    <flow id="f_S1_N2"  type="car" route="S1_N2"  begin="0" end="3600" vehsPerHour="60"/>
    <flow id="f_S1_S2"  type="car" route="S1_S2"  begin="0" end="3600" vehsPerHour="60"/>

    <flow id="f_E2_N1"  type="car" route="E2_N1"  begin="0" end="3600" vehsPerHour="80"/>
    <flow id="f_E2_S1"  type="car" route="E2_S1"  begin="0" end="3600" vehsPerHour="80"/>
    <flow id="f_N2_W1"  type="car" route="N2_W1"  begin="0" end="3600" vehsPerHour="80"/>
    <flow id="f_S2_W1"  type="car" route="S2_W1"  begin="0" end="3600" vehsPerHour="80"/>
</routes>
